# SQLCoder Configuration
USE_SQLCODER=false

# LLM Provider Configuration
# Options: api, ollama, lmstudio
LLM_PROVIDER=api

# API Provider Configuration
SQLCODER_API_URL=https://api.example.com/sqlcoder
SQLCODER_API_KEY=your_api_key_here

# Ollama Configuration
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=sqlcoder

# LM Studio Configuration
LMSTUDIO_URL=http://localhost:1234/v1/completions
LMSTUDIO_MODEL=sqlcoder

# Entity Extraction Configuration
USE_REGEX_EXTRACTOR=false